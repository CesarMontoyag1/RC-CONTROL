<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RC CONTROL"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SISTEMA LISTO"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Botón Conectar Estilizado -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintWidth_percent="0.75"
        android:text="VINCULAR DISPOSITIVO"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:backgroundTint="#FFFFFF"
        app:cornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"
        app:elevation="0dp"/>

    <!-- El Volante (Joystick Area) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/steeringWheelFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.95"
        app:cardBackgroundColor="#0A0A0A"
        app:cardCornerRadius="200dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A1A1A"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnConnect">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Botón Central STOP -->
            <!-- Nota: Invertimos los colores aquí para que destaque -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/ControlButtonStyle"
                android:layout_width="90dp"
                android:layout_height="90dp"
                app:icon="@drawable/ic_stop"
                app:iconTint="#000000"
                app:backgroundTint="#FFFFFF"
                app:strokeWidth="0dp"
                app:cornerRadius="45dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Controles Direccionales -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForward"
                style="@style/ControlButtonStyle"
                app:icon="@drawable/ic_arrow_up"
                app:layout_constraintBottom_toTopOf="@id/btnStop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/ControlButtonStyle"
                app:icon="@drawable/ic_arrow_down"
                app:layout_constraintTop_toBottomOf="@id/btnStop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLeft"
                style="@style/ControlButtonStyle"
                app:icon="@drawable/ic_arrow_left"
                app:layout_constraintEnd_toStartOf="@id/btnStop"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRight"
                style="@style/ControlButtonStyle"
                app:icon="@drawable/ic_arrow_right"
                app:layout_constraintStart_toEndOf="@id/btnStop"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginStart="16dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>